{
  "name": "pdf-text-editor",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Upload a PDF, edit its text in place, and download the result — all in the browser.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "test": "playwright test",
    "setup-ocr": "node scripts/setup-ocr.mjs"
  },
  "dependencies": {
    "@jsquash/jpeg": "^1.6.0",
    "@pdf-lib/fontkit": "^1.1.1",
    "lucide-react": "^1.26.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^4.7.76",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
